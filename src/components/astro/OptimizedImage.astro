---
interface Props {
  src: string;
  alt: string;
  class?: string;
  loading?: 'lazy' | 'eager';
  decoding?: 'sync' | 'async' | 'auto';
  fetchpriority?: 'high' | 'low' | 'auto';
}

const { 
  src, 
  alt, 
  class: className = '', 
  loading = 'lazy',
  decoding = 'async',
  fetchpriority = 'auto'
} = Astro.props;
---

<img
  src={src}
  alt={alt}
  class={className}
  loading={loading}
  decoding={decoding}
  fetchpriority={fetchpriority}
  width="100%"
  height="auto"
/>
